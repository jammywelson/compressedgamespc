# ============================================
# CompressedGamesPC — Environment Variables
# Copy this file to .env.local and fill in
# ============================================

# --- Admin Login (CHANGE THESE!) ---
NEXT_PUBLIC_ADMIN_USER="admin"
NEXT_PUBLIC_ADMIN_PASS="cgpc2025"

# --- Database (Free at neon.tech) ---
DATABASE_URL="postgresql://username:password@host:5432/compressedgamespc"

# --- Site URL ---
NEXT_PUBLIC_SITE_URL="https://compressedgamespc.com"

# --- Google Drive Backup (Optional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://compressedgamespc.com/api/gdrive/callback"

# --- Image Uploads (Optional - Cloudinary) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
